# Rybbit analytics - baked in at build time via Next.js standalone output.
# Leave blank to disable (site falls back to zero-analytics mode and the
# footer line becomes false, so don't do that in production).
RYBBIT_SITE_ID=
RYBBIT_URL=https://analytics.privdna.com

# Cloudflare Tunnel token for genomeprivate.com routing.
# Generate in Cloudflare Zero Trust -> Networks -> Tunnels -> Create.
# Route in the dashboard:
#   genomeprivate.com      -> http://genomeprivate-web:3000
#   www.genomeprivate.com  -> http://genomeprivate-web:3000
CLOUDFLARE_TUNNEL_TOKEN=
